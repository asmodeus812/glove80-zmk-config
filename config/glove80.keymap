#define ZMK_POINTING_DEFAULT_MOVE_VAL 1400  // default: 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 40    // default: 10
#define USER_CONFIG_DEFAULT_KEYMAP 1        // default: keymaps

